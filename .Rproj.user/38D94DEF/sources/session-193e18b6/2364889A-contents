# OBJECTIVE 1: Elevational effects

## 1A. Richness

### Data preparation

```{r
# Calculate richness per tree
species_cols <- names(comm)[!names(comm) %in% c("forof", "elevation")]

richness <- comm %>%
  mutate(richness = rowSums(across(all_of(species_cols), ~ . > 0))) %>%
  select(forof, elevation, richness)

richness$elev_f <- factor(richness$elevation)
```

### Model: Richness \~ Elevation

```{r
m_rich <- glmer(
  richness ~ elev_f + (1 | forof),
  family = poisson,
  data = richness
)

summary(m_rich)
Anova(m_rich)
```

### Pairwise comparisons

```{r
emm_rich <- emmeans(m_rich, ~ elev_f)
pairs(emm_rich, adjust = "tukey")
```

---

## 1B. Abundance

### Data preparation

```{r
abundance <- comm %>%
  mutate(abundance = rowSums(across(all_of(species_cols)))) %>%
  select(forof, elevation, abundance)

abundance$elev_f <- factor(abundance$elevation)
```

### Model: Abundance \~ Elevation

```{r
m_abun <- glmer(
  abundance ~ elev_f + (1 | forof),
  family = poisson,
  data = abundance
)

summary(m_abun)
Anova(m_abun)
```

### Pairwise comparisons

```{r
emm_abun <- emmeans(m_abun, ~ elev_f)
pairs(emm_abun, adjust = "tukey")
```

