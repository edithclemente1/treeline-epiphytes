Grafico BOXPLOT CON COMPARACIONES TUKEY
```{r}
#Extraer las comparaciones de emmeans como data frame
em <- emmeans(m_riq, ~ elev_f)
pairs_dif <- pairs(em, adjust = "tukey") %>%
  as.data.frame()
#data frame para ggplot
pairs_dif <- pairs_dif %>%
  separate(contrast, into = c("group1", "group2"), sep = " - ") %>%
  mutate(
    group1 = gsub("elev_f", "", group1),
    group2 = gsub("elev_f", "", group2),
    y.position = max(arboles$riqueza) + 
                 seq(0.2, by = 0.2, length.out = n())
  )

#GRAFICO con asteriscos
colnames(pairs_dif)
pairs_dif <- pairs_dif %>%
  mutate(
    p.signif = case_when(
      p.value < 0.001 ~ "***",
      p.value < 0.01  ~ "**",
      p.value < 0.05  ~ "*",
      TRUE            ~ "ns"
    )
  )
g_riqueza <- ggplot(arboles, aes(elev_f, riqueza)) +
  geom_boxplot() +
  geom_jitter(width = 0.1, alpha = 0.4) +
  stat_pvalue_manual(
    pairs_dif,
    label = "p.signif",
    tip.length = 0.01
  ) +
  theme_classic() +
  ylab("Epiphyte species richness per tree") +
  xlab("Elevation (m)")
g_riqueza
#corregir visualmente
pairs_si <- pairs_dif %>%
  filter(p.value < 0.05)
pairs_si <- pairs_si %>%
  mutate(
    y.position = max(arboles$riqueza, na.rm = TRUE) +
                 seq(2, by = 2, length.out = n())
  )
g_richness <- ggplot(arboles, aes(elev_f, riqueza)) +
  geom_boxplot(width = 0.6, outlier.shape = NA) +
  geom_jitter(width = 0.12, alpha = 0.5, size = 1.8) +
  stat_pvalue_manual(
    pairs_si,
    label = "p.signif",
    tip.length = 0.01
  ) +
  theme_classic(base_size = 14) +
  ylab("Epiphyte species richness") +
  xlab("Elevation (m)")
g_richness
#caption grafico: Boxes show median and interquartile range. Points represent individual trees.Asterisks indicate significant pairwise differences among elevations based on Tukey-adjusted estimated marginal means derived from the GLMM (* p < 0.05, ** p < 0.01).
