OB.2: Evaluar la influencia de la estructura (DAP y altura) y la identidad taxonómica (género) del árbol hospedero sobre la riqueza y abundancia de epífitas, controlando el efecto de la elevación.

1.- RIQUEZA
```{r}
#preparacion de datos escalar var numericas y elevacion como factor 
arboles$dap_z     <- scale(arboles$dap)
arboles$height_z  <- scale(arboles$height)
arboles$elev_z    <- scale(arboles$elevation)
arboles$elev_f      <- as.factor(arboles$elevation)
m_ricnb_h <- glmmTMB(
  riqueza ~ dap_z + height_z + (1 | elev_f),
  family = nbinom2,
  data = arboles
)
summary(m_ricnb_h)
Anova(m_ricnb_h, type = "II")
```
Grafico
```{r}
######################DAP
#GRAFICO con ejes reales pero usando la curva de prediccion
dap_mean <- attr(arboles$dap_z, "scaled:center")
dap_sd   <- attr(arboles$dap_z, "scaled:scale")
pred_dap <- ggpredict(m_ricnb_h, terms = "dap_z")
pred_dap$dap_real <- pred_dap$x * dap_sd + dap_mean

G_RIQ_DAP<- ggplot() +
  # Datos observados
  geom_point(
    data = arboles,
    aes(dap, riqueza),
    alpha = 0.4
  ) +
  # Predicción del modelo
  geom_line(
    data = pred_dap,
    aes(dap_real, predicted),
    size = 1
  ) +
  # Intervalo de confianza 95 %
  geom_ribbon(
    data = pred_dap,
    aes(dap_real, ymin = conf.low, ymax = conf.high),
    alpha = 0.25
  ) +
  # Etiquetas de ejes
  xlab("DBH (cm)") +
  ylab("Epiphyte species richness") +

  # Estilo final
  theme_classic(base_size = 14)
G_RIQ_DAP

###########ALTURA
pred_height <- ggpredict(
  m_ricnb_h,
  terms = "height_z"
)
height_mean <- attr(arboles$height_z, "scaled:center")
height_sd   <- attr(arboles$height_z, "scaled:scale")
pred_height$height_real <- pred_height$x * height_sd + height_mean
#GRAFICO
G_RIQ_H <- ggplot() +

  # Datos observados
  geom_point(
    data = arboles,
    aes(height, riqueza),
    alpha = 0.4
  ) +

  # Predicción del modelo
  geom_line(
    data = pred_height,
    aes(height_real, predicted),
    size = 1
  ) +

  # Intervalo de confianza 95 %
  geom_ribbon(
    data = pred_height,
    aes(height_real, ymin = conf.low, ymax = conf.high),
    alpha = 0.25
  ) +

  # Etiquetas
  xlab("Tree height (m)") +
  ylab("Epiphyte species richness") +

  # Estilo final
  theme_classic(base_size = 14)
G_RIQ_H

G_RIQ_H <- G_RIQ_H + #quita el eje del 2 plot
  theme(
    axis.title.y = element_blank(),
    axis.text.y  = element_blank(),
    axis.ticks.y = element_blank()
  )
#grafico junto
fig_riq_tree <- G_RIQ_DAP + G_RIQ_H +
  plot_layout(ncol = 2) +
  plot_annotation(tag_levels = "NULL")
G_RIQ_DAP <- G_RIQ_DAP +
  labs(tag = "A")

fig_riq_tree <- G_RIQ_DAP + G_RIQ_H +
  plot_layout(ncol = 2)

ggsave(
  filename = "Fig_riqueza_host_structure.tiff",
  plot     = fig_riq_tree,
  width    = 18,     # cm
  height   = 9,      # cm
  units    = "cm",
  dpi      = 600,
  compression = "lzw"
)
```
Figure 4. Effects of host tree structure on epiphyte species richness.
Predicted marginal effects of (A) diameter at breast height (DBH) and (B) tree height on epiphyte species richness per tree. Points represent observed richness values, and solid lines with shaded areas indicate predictions from negative binomial mixed-effects models and 95% confidence intervals. Elevational band was included as a random effect to account for variation associated with elevation.


