1.- RIQUEZA 
```{r}
#Riqueza mejor fit con elevacion como factor y hacer anova con grafico de boxplot con resultados de pairwise. 20FEB
arboles$elev_f <- factor(arboles$elevation)

m_riq <- glmer(riqueza ~ elev_f + (1|forof),
                family=poisson, data=arboles)
summary(m_riq)
Anova(m_riq)
check_model(m_riq)###valuar de forma rápida y visual si un modelo estadístico está bien especificado y si cumple los supuestos.1. linealidad, 2. homocedasticidad, 3. Normalidad de residuos, 4. Valores atipicos e influencia, 4. Colinearidad, Ajuste general del modelo
library(performance)##cuando no muestra el plot hace otra ventana
dev.new()
check_model(m_riq)
#################Modelo Binomial Negativo
m_ri <- glmmTMB(
  riqueza ~ elev_f + (1 | forof),
  family = nbinom2,
  data = arboles
)
library(performance)##cuando no muestra el plot hace otra ventana
dev.new()
check_model(m_ri)
summary(m_ri)
Anova(m_ri)
#comparacion por pares
emmeans(m_riq, list(pairwise ~ elev_f), adjust = "tukey")
#revisar overdispersion
check_overdispersion(m_riq)#sin overdispercion
