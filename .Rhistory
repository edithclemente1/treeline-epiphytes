supervivencia
str(supervivencia)
#preparar datos
library(dplyr)
supervivencia <- supervivencia %>%
mutate(
relocation = as.logical(relocation),
dead_alive = as.character(dead_alive)
)
surv_data <- supervivencia %>%#tabla de supervivencia
arrange(epi_ID, time) %>%
group_by(epi_ID) %>%
summarise(
group = first(relocation),               # TRUE = puna, FALSE = bosque
time_to_event = max(time),                # último tiempo observado
event = ifelse(any(dead_alive == "dead"), 1, 0)
)
surv_data <- surv_data %>%#T1 conviene transformarlo a número:
mutate(
time_num = as.numeric(gsub("T", "", time_to_event))
)
#Crear el objeto de supervivencia
library(survival)
S <- Surv(
time  = surv_data$time_num,
event = surv_data$event
)
#Ajustar Kaplan–Meier por grupo (Puna vs Bosque)
km_fit <- survfit(S ~ group, data = surv_data)
#6️⃣ Test estadístico: Log-rank test
logrank <- survdiff(S ~ group, data = surv_data)
logrank
#graficar curvas
library(survminer)
install.packages("survminer")
library(survminer)
ggsurvplot(
km_fit,
data = surv_data,
risk.table = TRUE,
pval = TRUE,
conf.int = FALSE,
legend.labs = c("Bosque", "Puna"),
xlab = "Tiempo",
ylab = "Probabilidad de supervivencia"
)
remove.packages("xfun")
install.packages("xfun")
remove.packages(c("xfun", "rmarkdown", "knitr", "survminer"))
install.packages("xfun")
install.packages("knitr")
install.packages("rmarkdown")
install.packages("survminer")
