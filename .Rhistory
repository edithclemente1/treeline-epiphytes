#Gráfico 3. Abundancia de epífitas por género del hospedero
library(dplyr)
library(ggplot2)
abund_plot <- abund_arbol %>%#preparar datos
group_by(genera_tree) %>%
mutate(mean_ab = mean(abundancia, na.rm = TRUE)) %>%
ungroup() %>%
mutate(genera_tree = reorder(genera_tree, mean_ab))
#grafico boxplot de todos los generos
ggplot(abund_plot, aes(x = genera_tree, y = abundancia)) +
# boxplot
geom_boxplot(
outlier.shape = NA,
fill = "grey80",
color = "black"
) +
# puntos individuales
geom_jitter(
width = 0.2,
alpha = 0.5,
size = 1
) +
scale_y_log10() +
labs(
x = "Género del árbol hospedero",
y = "Abundancia de epífitas"
) +
theme_classic(base_size = 13) +
theme(
axis.text.x = element_text(angle = 45, hjust = 1)
)
#grafico de solo los generos significativos
generos_sig <- c("Ilex", "Myrsine", "Oreopanax", "Weinmannia")
#filtrar los datos
abund_sig <- abund_arbol %>%
filter(genera_tree %in% generos_sig) %>%
group_by(genera_tree) %>%
mutate(mean_ab = mean(abundancia, na.rm = TRUE)) %>%
ungroup() %>%
mutate(genera_tree = reorder(genera_tree, mean_ab))
#grafico
ggplot(abund_sig, aes(x = genera_tree, y = abundancia)) +
geom_boxplot(
outlier.shape = NA,
fill = "grey80",
color = "black"
) +
geom_jitter(
width = 0.2,
alpha = 0.6,
size = 1.5
) +
scale_y_log10() +
labs(
x = "Host tree genera",
y = "Abundance (log)"
) +
theme_classic(base_size = 13)
ggsave(
filename = "Fig_Abundancia_Generos_significativos.png",
